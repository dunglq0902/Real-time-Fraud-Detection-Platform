    {
      "title": "Transaction Throughput (per minute)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 10,
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "targets": [
        {
          "rawSql": "SELECT toStartOfMinute(event_time) AS time, count() AS transactions, countIf(is_fraud = 1) AS detected_fraud, countIf(ground_truth_is_fraud = 1) AS ground_truth_fraud FROM fraud_detection.transactions WHERE event_time >= now() - INTERVAL 1 HOUR GROUP BY time ORDER BY time",
          "refId": "A",
          "format": 1
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "pointSize": 5
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "detected_fraud"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#f2495c",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.drawStyle",
                "value": "bars"
              }
            ]
          }
        ]
      }
    },
    {
      "title": "End-to-End Latency Over Time",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 44,
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "targets": [
        {
          "rawSql": "SELECT toStartOfMinute(decided_at) AS time, round(avg(dateDiff('millisecond', produced_at, decided_at)), 0) AS avg_latency_ms, round(quantile(0.95)(dateDiff('millisecond', produced_at, decided_at)), 0) AS p95_latency_ms, round(quantile(0.99)(dateDiff('millisecond', produced_at, decided_at)), 0) AS p99_latency_ms FROM fraud_detection.transactions WHERE produced_at > '1970-01-02' AND decided_at > '1970-01-02' AND decided_at >= now() - INTERVAL 1 HOUR GROUP BY time ORDER BY time",
          "refId": "A",
          "format": 1
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
