          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "p99_latency_ms"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#f2495c",
                  "mode": "fixed"
                }
              },
              {
